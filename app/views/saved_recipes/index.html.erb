<% content_for :title, "Saved Recipes" %>
<%= native_navbar_tag("Saved") %>

<h1 style="font-family:var(--font-display); font-size:1.5rem; margin-bottom:1rem;">Saved Recipes</h1>

<% if @recipes.any? %>
  <div class="recipe-grid">
    <% @recipes.each do |recipe| %>
      <%= render "shared/recipe_card", recipe: recipe %>
    <% end %>
  </div>
<% else %>
  <div style="text-align:center; padding:4rem 0; color:var(--text-secondary);">
    <p style="font-size:1.1rem;">No saved recipes yet.</p>
    <%= link_to "Browse recipes", recipes_path, class: "btn-gradient" %>
  </div>
<% end %>
