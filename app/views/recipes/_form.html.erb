<%= form_with model: recipe, multipart: true, data: { controller: "nested-form" } do |f| %>
  <% if recipe.errors.any? %>
    <div class="flash flash-alert">
      <strong><%= pluralize(recipe.errors.count, "error") %> prevented this recipe from being saved:</strong>
      <ul style="margin:0.5rem 0 0; padding-left:1.25rem;">
        <% recipe.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :title %>
    <%= f.text_field :title %>
  </div>

  <div>
    <%= f.label :description %>
    <%= f.text_area :description, rows: 4 %>
  </div>

  <div>
    <%= f.label :base_servings, "Servings" %>
    <%= f.number_field :base_servings, min: 1 %>
  </div>

  <div>
    <%= f.label :prep_time_mins, "Prep time (minutes)" %>
    <%= f.number_field :prep_time_mins, min: 0 %>
  </div>

  <div>
    <%= f.label :cook_time_mins, "Cook time (minutes)" %>
    <%= f.number_field :cook_time_mins, min: 0 %>
  </div>

  <div>
    <%= f.label :cover_image, "Cover photo" %>
    <%= f.file_field :cover_image, accept: "image/*" %>
    <% if recipe.cover_image.present? %>
      <%= image_tag recipe.cover_image.thumb.url, alt: "Current cover", style: "margin-top:0.5rem; border-radius:var(--radius-sm); max-height:120px;" %>
      <%= f.hidden_field :cover_image_cache %>
    <% end %>
  </div>

  <div>
    <%= f.label :status %>
    <%= f.select :status, Recipe.statuses.keys.map { |s| [s.humanize, s] }, { selected: recipe.new_record? ? "published" : recipe.status } %>
  </div>

  <%# ── INGREDIENTS ── %>
  <h3 style="margin-top:2rem;">Ingredients</h3>

  <div data-nested-form-target="list" data-list-id="ingredients">
    <% f.fields_for :ingredients do |ing| %>
      <div data-nested-row style="display:flex; gap:0.5rem; align-items:center; margin-bottom:0.5rem;">
        <%= ing.hidden_field :_destroy %>
        <%= ing.text_field  :name,   placeholder: "Name",   style: "flex:2;" %>
        <%= ing.number_field :amount, placeholder: "Amount", step: "0.001", min: 0, style: "flex:1;" %>
        <%= ing.select :unit, Ingredient::UNITS.keys.map { |u| [u.to_s.humanize, u] }, {}, style: "flex:1;" %>
        <button type="button" data-action="nested-form#remove" style="flex-shrink:0; background:none; border:none; color:var(--text-secondary); cursor:pointer; font-size:1.1rem;" title="Remove">✕</button>
      </div>
    <% end %>
  </div>

  <template data-nested-form-target="template" data-list-id="ingredients">
    <div data-nested-row style="display:flex; gap:0.5rem; align-items:center; margin-bottom:0.5rem;">
      <input type="text"   name="recipe[ingredients_attributes][NEW_RECORD][name]"   placeholder="Name"   style="flex:2;" class="form-control">
      <input type="number" name="recipe[ingredients_attributes][NEW_RECORD][amount]" placeholder="Amount" step="0.001" min="0" style="flex:1;" class="form-control">
      <select name="recipe[ingredients_attributes][NEW_RECORD][unit]" style="flex:1;">
        <% Ingredient::UNITS.keys.each do |u| %>
          <option value="<%= u %>"><%= u.to_s.humanize %></option>
        <% end %>
      </select>
      <button type="button" data-action="nested-form#remove" style="flex-shrink:0; background:none; border:none; color:var(--text-secondary); cursor:pointer; font-size:1.1rem;" title="Remove">✕</button>
    </div>
  </template>

  <button type="button" class="btn-outline" style="margin-top:0.5rem; padding:0.4rem 1rem; font-size:0.85rem;"
          data-action="nested-form#add" data-list-id="ingredients">
    + Add Ingredient
  </button>

  <%# ── STEPS ── %>
  <h3 style="margin-top:2rem;">Steps</h3>

  <div data-nested-form-target="list" data-list-id="steps">
    <% f.fields_for :steps do |step| %>
      <div data-nested-row style="margin-bottom:1rem; background:var(--card-bg); border:1px solid var(--border); border-radius:var(--radius-sm); padding:0.75rem;">
        <%= step.hidden_field :_destroy %>
        <%= step.text_area :instruction, placeholder: "Describe this step…", rows: 2, style: "width:100%; margin-bottom:0.5rem;" %>
        <%= step.file_field :image, accept: "image/*", style: "font-size:0.85rem;" %>
        <div style="text-align:right; margin-top:0.5rem;">
          <button type="button" data-action="nested-form#remove" style="background:none; border:none; color:var(--text-secondary); cursor:pointer; font-size:0.85rem;">Remove step</button>
        </div>
      </div>
    <% end %>
  </div>

  <template data-nested-form-target="template" data-list-id="steps">
    <div data-nested-row style="margin-bottom:1rem; background:var(--card-bg); border:1px solid var(--border); border-radius:var(--radius-sm); padding:0.75rem;">
      <textarea name="recipe[steps_attributes][NEW_RECORD][instruction]" placeholder="Describe this step…" rows="2" style="width:100%; margin-bottom:0.5rem;"></textarea>
      <input type="file" name="recipe[steps_attributes][NEW_RECORD][image]" accept="image/*" style="font-size:0.85rem;">
      <div style="text-align:right; margin-top:0.5rem;">
        <button type="button" data-action="nested-form#remove" style="background:none; border:none; color:var(--text-secondary); cursor:pointer; font-size:0.85rem;">Remove step</button>
      </div>
    </div>
  </template>

  <button type="button" class="btn-outline" style="margin-top:0.5rem; padding:0.4rem 1rem; font-size:0.85rem;"
          data-action="nested-form#add" data-list-id="steps">
    + Add Step
  </button>

  <div style="margin-top:2rem;">
    <%= f.submit class: "btn-gradient" %>
  </div>
<% end %>
