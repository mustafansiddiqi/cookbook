<% content_for :title, "All Recipes" %>
<%= native_navbar_tag("Feed") %>

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem;">
  <h1 style="font-family:var(--font-display); font-size:1.5rem; margin:0;">Feed</h1>
  <% if user_signed_in? %>
    <%= link_to "+ Recipe", new_recipe_path, class: "btn-gradient" %>
  <% end %>
</div>

<% if @recipes.any? %>
  <div class="recipe-grid">
    <% @recipes.each do |recipe| %>
      <%= render "shared/recipe_card", recipe: recipe %>
    <% end %>
  </div>
<% else %>
  <div style="text-align:center; padding:4rem 0; color:var(--text-secondary);">
    <p style="font-size:1.1rem;">No recipes yet.</p>
    <% if user_signed_in? %>
      <%= link_to "Post the first one!", new_recipe_path, class: "btn-gradient" %>
    <% end %>
  </div>
<% end %>
