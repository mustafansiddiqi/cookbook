<nav class="site-nav">
  <div class="nav-inner">
    <%= link_to "Cookbook", root_path, class: "nav-brand" %>

    <div class="nav-links">
      <% if user_signed_in? %>
        <%= link_to "Feed", recipes_path %>
        <%= link_to "Saved", saved_recipes_path %>
        <% if current_user.avatar.present? %>
          <%= link_to user_path(current_user) do %>
            <%= image_tag current_user.avatar.thumb.url,
                  alt: current_user.username,
                  style: "width:32px;height:32px;border-radius:50%;object-fit:cover;vertical-align:middle;" %>
          <% end %>
        <% else %>
          <%= link_to user_path(current_user), class: "nav-avatar",
                title: current_user.display_name.presence || current_user.username do %>
            <%= (current_user.display_name.presence || current_user.username)[0].upcase %>
          <% end %>
        <% end %>
        <%= link_to "+ Recipe", new_recipe_path, class: "btn-gradient" %>
        <%= button_to "Sign out", destroy_user_session_path, method: :delete,
              class: "btn-outline nav-signout",
              form: { style: "display:inline;" } %>
      <% else %>
        <%= link_to "Sign in", new_user_session_path %>
        <%= link_to "Sign up", new_user_registration_path, class: "btn-gradient" %>
      <% end %>
    </div>
  </div>
</nav>
