<div class="form-card" style="margin-top: 2rem;">
  <h1 style="margin-bottom: 1.5rem;">Edit Profile</h1>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <label>Username</label>
    <%= f.text_field :username %>

    <label>Display Name</label>
    <%= f.text_field :display_name %>

    <label>Email</label>
    <%= f.email_field :email %>

    <label>Bio</label>
    <%= f.text_area :bio, rows: 3 %>

    <hr>
    <h3 style="font-size:1rem; margin-bottom:1rem;">Change Password</h3>

    <label>New Password <span class="text-muted">(leave blank to keep current)</span></label>
    <%= f.password_field :password, autocomplete: "new-password" %>

    <label>Confirm New Password</label>
    <%= f.password_field :password_confirmation %>

    <label>Current Password <span class="text-muted">(required to save changes)</span></label>
    <%= f.password_field :current_password %>

    <div style="margin-top: 1.5rem; display: flex; gap: 0.75rem;">
      <%= f.submit "Save Changes", class: "btn-gradient" %>
      <%= link_to "Cancel", :back, class: "btn-outline" %>
    </div>
  <% end %>

  <hr style="margin: 2rem 0;">
  <h3 style="color: #dc2743; font-size:0.95rem;">Danger Zone</h3>
  <%= button_to "Delete my account", registration_path(resource_name), data: { confirm: "Are you sure? This cannot be undone.", turbo_confirm: "Are you sure?" }, method: :delete, class: "btn-outline", style: "border-color: #dc2743; color: #dc2743;" %>
</div>
