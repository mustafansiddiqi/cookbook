<div class="auth-container">
  <div class="auth-logo">📖 Cookbook</div>

  <div class="auth-card">
    <h2 style="font-size:1.1rem; margin-bottom:1.25rem; color: var(--text-secondary); font-family: var(--font-body); font-weight:400;">
      Sign up to share your recipes
    </h2>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= f.text_field :username, placeholder: "Username" %>
      <%= f.text_field :display_name, placeholder: "Full Name" %>
      <%= f.email_field :email, placeholder: "Email" %>
      <%= f.password_field :password, placeholder: "Password" %>
      <%= f.password_field :password_confirmation, placeholder: "Confirm Password" %>

      <%= f.submit "Sign up", class: "btn-gradient" %>
    <% end %>
  </div>

  <div class="auth-switch">
    Already have an account? <%= link_to "Sign in", new_session_path(resource_name), style: "color: var(--brand-pink); font-weight:600;" %>
  </div>
</div>
