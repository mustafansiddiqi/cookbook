<div class="auth-container">
  <div class="auth-logo">📖 Cookbook</div>

  <div class="auth-card">
    <h2 style="font-size:1.1rem; margin-bottom:1.25rem; color: var(--text-secondary); font-family: var(--font-body); font-weight:400;">
      Sign in to see recipes from friends
    </h2>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <%= f.email_field :email, placeholder: "Email", autofocus: true %>
      <%= f.password_field :password, placeholder: "Password" %>

      <% if devise_mapping.rememberable? %>
        <label style="font-size:0.85rem; text-transform:none; letter-spacing:0; display:flex; align-items:center; gap:0.4rem; margin-bottom:1rem; color: var(--text-primary);">
          <%= f.check_box :remember_me %> Remember me
        </label>
      <% end %>

      <%= f.submit "Sign in", class: "btn-gradient" %>
    <% end %>

    <div style="margin-top:1rem;">
      <%= render "devise/shared/links" %>
    </div>
  </div>

  <div class="auth-switch">
    Don't have an account? <%= link_to "Sign up", new_registration_path(resource_name), style: "color: var(--brand-pink); font-weight:600;" %>
  </div>
</div>
